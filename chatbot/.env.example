ANTHROPIC_API_KEY=sk-ant-your-key-here
DETECTOR_URL=http://localhost:8000/analyze

# Optional — set in production (must match detector service)
# DETECTOR_API_KEY=your-detector-key
# ADMIN_API_KEY=your-admin-key

# If the detector Vercel project has Deployment Protection enabled, paste the
# "Protection Bypass for Automation" secret from that detector project here:
# VERCEL_PROTECTION_BYPASS=your-bypass-secret

# Required for /api/inject-message when set (must match detector RED_TEAM_API_KEY)
# RED_TEAM_API_KEY=your-red-team-key

# Local dev only — allow chat when detector is offline (default: false)
# DETECTOR_FAIL_OPEN=true

# Block suspicious warn-tier messages (default: true)
# BLOCK_WARN_ACTION=true

# Rate limiting
# RATE_LIMIT_CHAT=30
# RATE_LIMIT_WINDOW_SECONDS=60

# CORS (comma-separated origins)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
# COOKIE_SECURE=true
